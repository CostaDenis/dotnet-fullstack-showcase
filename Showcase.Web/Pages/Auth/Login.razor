@page "/"
@layout HeadlessLayout
@inherits LoginPage

<PageTitle>Entrar - Showcase</PageTitle>

<div class="flex items-center justify-center min-h-screen p-6 bg-background">

    <Toast @ref="Toast" />

    <div class="w-full max-w-md">

        <div class="flex flex-col items-center mb-8">
            <img src="imgs/logo/showcase.png" class="h-auto mb-4 w-28">

            <h1 class="text-3xl fonto-bold text-foreground">
                Bem vindo de volta
            </h1>

        </div>

        <EditForm Model="@LoginRequest" OnValidSubmit="HandleLoginAsync"
                  class="flex flex-col gap-5 p-8 border shadow-xl bg-surface border-border roundend-2xl">

            <div class="text-base text-wrong">
                <DataAnnotationsValidator />
                <ValidationSummary />
            </div>

            <div class="flex flex-col gap-2">

                <Label Text="Email" For="Email" />

                <InputText @bind-Value="LoginRequest.Email" placeholder="seu@email.com" type="text" id="Email"
                           class="w-full px-4 py-3 transition-all duration-200 border outline-none bg-background border-border rounded-xl text-foreground placeholder:text-muted focus:border-primary focus:ring-2 focus:ring-primary/20" />

            </div>

            <div class="flex flex-col gap-2">

                <Label Text="Senha" For="Password" />

                <InputText @bind-Value="LoginRequest.Password" placeholder="Senha" type="password" id="Password"
                           class="w-full px-4 py-3 transition-all duration-200 border outline-none bg-background border-border rounded-xl text-foreground placeholder:text-muted focus:border-primary focus:ring-2 focus:ring-primary/20" />

            </div>

            <SubmitButton Text="Entrar" />

            <a href="/forgot-password" class="text-center text-primary hover:underline">
                Esqueceu a senha?
            </a>

        </EditForm>

    </div>

</div>